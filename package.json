{
  "name": "rr7-clean-arch",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:migrate && npm run db:seed",
    "build": "react-router build",
    "dev": "react-router dev",
    "prestart": "npm run db:migrate && npm run db:seed",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node ./scripts/db-seed.mjs"
  },
  "dependencies": {
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-backend": "^3.0.2",
    "i18next-icu": "^2.4.1",
    "isbot": "^5.1.36",
    "pg": "^8.16.3",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.1.0",
    "react-router": "7.13.2"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
